# 東京メトロ (Metpo)
TOKYO_METRO_EMAIL=your_email@example.com
TOKYO_METRO_PASSWORD=your_password

# 都営地下鉄 (Tokopo)
TOEI_USER_ID=your_user_id
TOEI_METRO_PASSWORD=your_password

# 東急 (Tokyu)
# 東急はセッション情報をブラウザから取得する必要があります
# Cookie名: __Host-plus.sessionToken
TOKYU_EMAIL=your_email@example.com
TOKYU_PASSWORD=your_password

# 相鉄 (Sotetsu)
SOTETSU_EMAIL=your_email@example.com
SOTETSU_PASSWORD=your_password

# 京急 (Keikyu)
KEIKYU_LOGIN_ID=your_id
KEIKYU_PASSWORD=your_password
